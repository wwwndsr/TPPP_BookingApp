<Window x:Class="BookingApp.Views.CloneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клонирование брони (Prototype)" 
        Height="550" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        FontFamily="Segoe UI"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для ComboBox без CornerRadius -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderBrush" Value="#6C5CE7"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <ToggleButton x:Name="toggleButton" 
                                                  Grid.Column="2" 
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderBrush="Transparent"/>
                                    <ContentPresenter x:Name="contentPresenter" 
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding ItemTemplate}"
                                                      Margin="10,0,30,0"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="popup" 
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom">
                                <Border BorderBrush="#6C5CE7" 
                                        BorderThickness="2" 
                                        CornerRadius="8"
                                        Background="White">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#00B894"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Background="#6C5CE7" 
                CornerRadius="10" 
                Padding="15" 
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="🧬 Клонирование брони (Prototype)" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Создание копий существующей брони" 
                           FontSize="12" 
                           Foreground="#E0E0E0" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка: Исходная бронь -->
            <Border Grid.Column="0" 
                    Background="White" 
                    CornerRadius="15" 
                    Padding="20"
                    BorderBrush="#6C5CE7"
                    BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="📋 ИСХОДНАЯ БРОНЬ" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#6C5CE7"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Выберите бронь для клонирования:" 
                               FontSize="12"
                               Foreground="#7F8C8D"
                               Margin="0,0,0,5"/>

                    <!-- ComboBox с правильным стилем -->
                    <ComboBox x:Name="cmbSourceBooking" 
                              Style="{StaticResource ModernComboBox}"
                              Height="40"
                              Margin="0,0,0,15"
                              SelectionChanged="CmbSourceBooking_SelectionChanged"/>

                    <!-- Карточка выбранной брони -->
                    <Border Background="#F8F9FA" 
                            CornerRadius="10" 
                            Padding="15"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="txtSourceGuest" 
                                       Text="👤 Гость: не выбран"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtSourceHotel" 
                                       Text="🏨 Отель: -"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtSourceRoom" 
                                       Text="🛏️ Номер: -"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtSourceServices" 
                                       Text="🍽️ Услуги: -"
                                       FontSize="14"
                                       Margin="0,0,0,8"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="txtSourcePrice" 
                                       Text="💰 Цена: -"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#00B894"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Правая колонка: Настройки клонирования -->
            <Border Grid.Column="2" 
                    Background="White" 
                    CornerRadius="15" 
                    Padding="20"
                    BorderBrush="#00B894"
                    BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="⚙️ НАСТРОЙКИ КЛОНИРОВАНИЯ" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#00B894"
                               Margin="0,0,0,15"/>

                    <!-- Количество копий -->
                    <TextBlock Text="Количество копий:" 
                               FontSize="14"
                               Foreground="#2D3436"
                               Margin="0,0,0,5"/>

                    <Slider x:Name="sliderCopyCount" 
                            Minimum="1" 
                            Maximum="20" 
                            Value="3"
                            TickFrequency="1"
                            TickPlacement="BottomRight"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,5"/>

                    <TextBlock x:Name="txtCopyCount" 
                               Text="3 копии"
                               FontSize="14"
                               Foreground="#00B894"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,15"/>

                    <!-- Префикс для имени -->
                    <TextBlock Text="Префикс для имени:" 
                               FontSize="14"
                               Foreground="#2D3436"
                               Margin="0,0,0,5"/>

                    <!-- TextBox с правильным стилем -->
                    <TextBox x:Name="txtNamePrefix" 
                             Text="Гость (копия)"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,15"/>

                    <!-- Дополнительные опции -->
                    <Border Background="#F8F9FA" 
                            CornerRadius="10" 
                            Padding="15"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <CheckBox x:Name="chkSaveToManager" 
                                      Content="Сохранить в менеджер броней"
                                      IsChecked="True"
                                      FontSize="14"
                                      Margin="0,5"/>
                            <CheckBox x:Name="chkIncrementNumber" 
                                      Content="Добавлять номер к имени"
                                      IsChecked="True"
                                      FontSize="14"
                                      Margin="0,5"/>
                        </StackPanel>
                    </Border>

                    <!-- Предпросмотр -->
                    <Border Background="#E3F2FD" 
                            CornerRadius="10" 
                            Padding="15">
                        <StackPanel>
                            <TextBlock Text="ПРЕДПРОСМОТР:" 
                                       FontSize="12"
                                       Foreground="#1976D2"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="txtPreview" 
                                       Text="Будет создано 3 копии"
                                       FontSize="14"
                                       Foreground="#1976D2"
                                       Margin="0,5,0,0"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="txtPreviewNames" 
                                       Text="Гость (копия) 1, Гость (копия) 2, ..."
                                       FontSize="12"
                                       Foreground="#555"
                                       Margin="0,5,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Кнопки -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" 
                    Content="❌ Отмена"
                    Style="{StaticResource ModernButton}"
                    Background="#E0E0E0"
                    Foreground="#2D3436"
                    Click="BtnCancel_Click"/>

            <Button Grid.Column="3" 
                    Content="✅ Создать копии"
                    Style="{StaticResource ModernButton}"
                    Background="#00B894"
                    Foreground="White"
                    Click="BtnClone_Click"/>
        </Grid>
    </Grid>
</Window>