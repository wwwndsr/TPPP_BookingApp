<Window x:Class="BookingApp.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Администрирование (Proxy)" 
        Height="500" Width="650"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="🔒 АДМИНИСТРИРОВАНИЕ (Proxy)" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Foreground="#E74C3C"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- Панель входа -->
        <Border Grid.Row="1" 
                Background="#F0F0F0" 
                CornerRadius="8" 
                Padding="15"
                BorderBrush="#E74C3C"
                BorderThickness="2">

            <StackPanel x:Name="LoginPanel" Width="300">
                <TextBlock Text="Введите пароль администратора:" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="30" Margin="0,0,0,10"/>
                <Button x:Name="btnLogin" 
                        Content="Войти" 
                        Height="35"
                        Background="#E74C3C" 
                        Foreground="White"
                        Click="BtnLogin_Click"/>
                <TextBlock x:Name="txtLoginError" Foreground="Red" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Панель администратора -->
        <StackPanel x:Name="AdminPanel" 
                    Grid.Row="2" 
                    Margin="0,10,0,0"
                    Visibility="Collapsed">

            <TextBlock Text="✅ Админ-панель" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Foreground="#27AE60"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Все бронирования:" FontWeight="SemiBold" Margin="0,0,0,5"/>

            <ListBox x:Name="lstBookings" Height="200" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnRefresh" 
                        Content="Обновить" 
                        Width="80" 
                        Height="30"
                        Margin="0,0,10,0"
                        Click="BtnRefresh_Click"/>
                <Button x:Name="btnLogout" 
                        Content="Выйти" 
                        Width="80" 
                        Height="30"
                        Background="#E74C3C" 
                        Foreground="White"
                        Click="BtnLogout_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Статус -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <TextBlock x:Name="txtStatus" Text="Требуется авторизация" Foreground="#7F8C8D"/>
        </StatusBar>
    </Grid>
</Window>