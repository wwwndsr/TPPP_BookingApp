<Window x:Class="BookingApp.Views.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookingApp"
        mc:Ignorable="d"
        Title="Booking App" 
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="#F5F5F5">

    <Grid x:Name="MainRoot" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Background="#2C3E50" 
                CornerRadius="10" 
                Padding="15" 
                Margin="0,0,0,20">
            <TextBlock Text="СИСТЕМА БРОНИРОВАНИЯ ОТЕЛЕЙ" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,0,20">
            <StackPanel>

                <!-- 1. Abstract Factory - Выбор отеля -->
                <Border Background="White" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0,0,0,15"
                        BorderBrush="#3498DB" 
                        BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="1. ВЫБОР ОТЕЛЯ (Abstract Factory)" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#3498DB" 
                                   Margin="0,0,0,15"/>

                        <RadioButton x:Name="rdCityHotel" 
                                     Content="🏙️ Городской отель (номер + завтрак)" 
                                     GroupName="HotelType" 
                                     IsChecked="True"
                                     FontSize="14" 
                                     Margin="0,5"
                                     Checked="rdCityHotel_Checked"/>

                        <RadioButton x:Name="rdResortHotel" 
                                     Content="🏖️ Курортный отель (номер + СПА + бассейн)" 
                                     GroupName="HotelType"
                                     FontSize="14" 
                                     Margin="0,5"
                                     Checked="rdResortHotel_Checked"/>

                        <TextBlock x:Name="txtHotelServices" 
                                   Text="Доступные услуги: Завтрак" 
                                   Foreground="#27AE60" 
                                   FontStyle="Italic" 
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 2. Factory Method - Тип номера -->
                <Border Background="White" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0,0,0,15"
                        BorderBrush="#E74C3C" 
                        BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="2. ТИП НОМЕРА (Factory Method)" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#E74C3C" 
                                   Margin="0,0,0,15"/>

                        <WrapPanel>
                            <RadioButton x:Name="rdSingleRoom" 
                                         Content="🛏️ Одноместный (€200/ночь)" 
                                         GroupName="RoomType" 
                                         IsChecked="True"
                                         FontSize="14" 
                                         Margin="0,5,30,5"
                                         Checked="rdSingleRoom_Checked"/>

                            <RadioButton x:Name="rdLuxRoom" 
                                         Content="✨ Люкс (€500/ночь)" 
                                         GroupName="RoomType"
                                         FontSize="14" 
                                         Margin="0,5,30,5"
                                         Checked="rdLuxRoom_Checked"/>

                            <RadioButton x:Name="rdApartment" 
                                         Content="🏢 Апартаменты (€800/ночь)" 
                                         GroupName="RoomType"
                                         FontSize="14" 
                                         Margin="0,5"
                                         Checked="rdApartment_Checked"/>
                        </WrapPanel>

                        <TextBlock x:Name="txtRoomDescription" 
                                   Text="Одноместный номер: 1 кровать, Wi-Fi, ТВ" 
                                   Foreground="#7F8C8D" 
                                   FontStyle="Italic" 
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 3. Builder - Дополнительные услуги -->
                <Border Background="White" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0,0,0,15"
                        BorderBrush="#F39C12" 
                        BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="3. ДОПОЛНИТЕЛЬНЫЕ УСЛУГИ (Builder)" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#F39C12" 
                                   Margin="0,0,0,15"/>

                        <CheckBox x:Name="chkBreakfast" 
                                  Content="🍳 Завтрак (€50/день)" 
                                  FontSize="14" 
                                  Margin="0,5"
                                  Checked="CheckBox_Changed"
                                  Unchecked="CheckBox_Changed"/>

                        <CheckBox x:Name="chkTransfer" 
                                  Content="🚗 Трансфер (€150)" 
                                  FontSize="14" 
                                  Margin="0,5"
                                  Checked="CheckBox_Changed"
                                  Unchecked="CheckBox_Changed"/>

                        <CheckBox x:Name="chkMinibar" 
                                  Content="🍸 Мини-бар (€100/день)" 
                                  FontSize="14" 
                                  Margin="0,5"
                                  Checked="CheckBox_Changed"
                                  Unchecked="CheckBox_Changed"/>

                        <CheckBox x:Name="chkLateCheckout" 
                                  Content="⏰ Поздний выезд (€100)" 
                                  FontSize="14" 
                                  Margin="0,5"
                                  Checked="CheckBox_Changed"
                                  Unchecked="CheckBox_Changed"/>

                        <TextBlock x:Name="txtServicesTotal" 
                                   Text="Дополнительные услуги: €0" 
                                   Foreground="#E67E22" 
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Right" 
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 4. Данные гостя с placeholder -->
                <Border Background="White" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="4. ДАННЫЕ ГОСТЯ" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#34495E" 
                                   Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Имя:" 
                                       FontSize="14" 
                                       VerticalAlignment="Center"/>

                            <!-- Поле для имени с placeholder -->
                            <Grid Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,0,10">
                                <TextBox x:Name="txtGuestName" 
                                         Height="30" 
                                         Padding="5"
                                         VerticalAlignment="Center"
                                         Background="Transparent"
                                         BorderBrush="#CCCCCC"
                                         BorderThickness="1"
                                         TextChanged="txtGuestName_TextChanged"
                                         GotFocus="txtGuestName_GotFocus"
                                         LostFocus="txtGuestName_LostFocus"/>

                                <TextBlock x:Name="txtGuestNamePlaceholder" 
                                           Text="Введите ФИО" 
                                           Foreground="Gray"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"
                                           Visibility="Visible"/>
                            </Grid>

                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       Text="Email:" 
                                       FontSize="14" 
                                       VerticalAlignment="Center"/>

                            <!-- Поле для email с placeholder -->
                            <Grid Grid.Row="1" Grid.Column="1" Height="30">
                                <TextBox x:Name="txtGuestEmail" 
                                         Height="30" 
                                         Padding="5"
                                         VerticalAlignment="Center"
                                         Background="Transparent"
                                         BorderBrush="#CCCCCC"
                                         BorderThickness="1"
                                         TextChanged="txtGuestEmail_TextChanged"
                                         GotFocus="txtGuestEmail_GotFocus"
                                         LostFocus="txtGuestEmail_LostFocus"/>

                                <TextBlock x:Name="txtGuestEmailPlaceholder" 
                                           Text="Введите e-mail" 
                                           Foreground="Gray"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"
                                           Visibility="Visible"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Панель с текущим пакетом и итоговой ценой -->
        <Border Grid.Row="2" 
                Background="#34495E" 
                CornerRadius="10" 
                Padding="20" 
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ТЕКУЩИЙ ПАКЕТ БРОНИРОВАНИЯ" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="txtBookingSummary" 
                               Text="Отель: не выбран | Номер: не выбран | Услуги: нет" 
                               Foreground="#ECF0F1" 
                               FontSize="14" 
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                            HorizontalAlignment="Right">
                    <TextBlock Text="ИТОГО:" 
                               FontSize="14" 
                               Foreground="#F1C40F" 
                               HorizontalAlignment="Right"/>

                    <TextBlock x:Name="txtTotalPrice" 
                               Text="€0" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="#F1C40F"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопки действий -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Кнопка для Prototype (будет открывать окно клонирования) -->
            <Button x:Name="btnCloneBooking" 
                    Grid.Column="1" 
                    Content="Клонировать бронь" 
                    Width="200" 
                    Height="40" 
                    Background="#9B59B6" 
                    Foreground="White" 
                    FontSize="14" 
                    FontWeight="SemiBold" 
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnCloneBooking_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="20"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="btnBookNow" 
                    Grid.Column="3" 
                    Content="ЗАБРОНИРОВАТЬ" 
                    Width="200" 
                    Height="40" 
                    Background="#27AE60" 
                    Foreground="White" 
                    FontSize="14" 
                    FontWeight="Bold" 
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnBookNow_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="20"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Статус бар -->
        <StatusBar Grid.Row="4" 
                   Margin="0,10,0,0" 
                   Background="Transparent">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" 
                           Text="Готов к бронированию" 
                           Foreground="#7F8C8D"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>