<Window x:Class="BookingApp.Views.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тестовое окно" Height="300" Width="400">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Список тестовых данных:" FontWeight="Bold" Margin="0,0,0,10"/>
            <ListBox x:Name="lstTest" Height="150"/>
            <Button x:Name="btnLoad" Content="Загрузить тестовые данные" Height="30" Margin="0,10,0,0" Click="BtnLoad_Click"/>
        </StackPanel>
    </Grid>
</Window>